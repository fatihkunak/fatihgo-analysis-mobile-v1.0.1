{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "env": {
          "npm_config_legacy_peer_deps": "true"
        }
      },
      "ios": {
        "simulator": true
      }
    },
    "preview2": {
      "android": {
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "preview3": {
      "developmentClient": true
    },
    "production": {
      "android": {
        "buildType": "apk",
        "env": {
          "npm_config_legacy_peer_deps": "true"
        }
      },
      "ios": {}
    }
  },
  "submit": {
    "production": {}
  }
}
